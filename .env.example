# Copy to .env.local and adjust.

ANTHROPIC_API_KEY=

# Optional: override model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 로컬 Docker: docker compose up -d 후 아래 URL 사용
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/expression_bank?schema=public"

# Neon(Vercel 배포용): 대시보드에서 복사한 연결 문자열 (sslmode=require 포함 권장)
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"
